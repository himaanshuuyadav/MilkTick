# Firebase Configuration
# Copy this file to .env and fill in your Firebase credentials
# Get these values from your Firebase Console > Project Settings > google-services.json

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APPLICATION_ID=your-application-id
FIREBASE_API_KEY=your-api-key
FIREBASE_DATABASE_URL=your-database-url
FIREBASE_STORAGE_BUCKET=your-storage-bucket

# Note: Do not commit .env or google-services.json to version control
